# =============================================================================
# Hoku Health Care - Environment Variables Template
# Copy this file to .env and fill in real values before running.
# =============================================================================

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://hoku_user:hoku_pass@localhost:5432/hoku_health

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Groq AI (https://console.groq.com/keys)
# =============================================================================
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_FAST_MODEL=llama3-8b-8192
GROQ_MAIN_MODEL=llama3-70b-8192

# =============================================================================
# AI Hyperparameters (Day 2 - Clinical Safety & Latency Tuning)
# =============================================================================
# Temperature: 0.3 reduces hallucination in medical context while keeping
# natural language variation. Higher = more creative (unsafe for diagnosis).
# Lower = robotic but safer. 0.3 is the clinical sweet spot.
TEMPERATURE=0.3

# Max tokens: 512 caps response length to guarantee Groq call + JSON parsing
# + DB persistence completes within the 3.5s hard timeout, leaving 0.5s buffer
# before the 4s NFR ceiling.
MAX_TOKENS=512

# Hard timeout: 3.5s ensures fallback triggers before user perceives delay.
# Must stay under NFR-02 limit of 4.0s.
GROQ_TIMEOUT_SECONDS=3.5

# Retry policy: 3 attempts with exponential backoff (1s, 2s, 4s).
# Total worst-case bounded so we never breach the hard timeout.
MAX_RETRIES=3
RETRY_BACKOFF_BASE_SECONDS=1.0

# =============================================================================
# Embeddings (stubbed for RAG pipeline - Day 4+)
# =============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
DEBUG=True