# =============================================================================
# Hoku Health Care - Environment Variables Template
# Copy this file to .env and fill in real values before running.
# =============================================================================

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://hoku_user:hoku_pass@localhost:5432/hoku_health

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Groq AI (https://console.groq.com/keys)
# =============================================================================
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_MAIN_MODEL=llama-3.3-70b-versatile

# =============================================================================
# AI Hyperparameters (Day 2 - Clinical Safety & Latency Tuning)
# =============================================================================
# Temperature: 0.3 reduces hallucination in medical context while keeping
# natural language variation. Higher = more creative (unsafe for diagnosis).
# Lower = robotic but safer. 0.3 is the clinical sweet spot.
TEMPERATURE=0.3

# Max tokens: 512 caps response length to guarantee Groq call + JSON parsing
# + DB persistence completes within the 3.5s hard timeout, leaving 0.5s buffer
# before the 4s NFR ceiling.
MAX_TOKENS=512

# Hard timeout: 3.5s ensures fallback triggers before user perceives delay.
# Must stay under NFR-02 limit of 4.0s.
GROQ_TIMEOUT_SECONDS=3.5

# Retry policy: 3 attempts with exponential backoff (1s, 2s, 4s).
# Total worst-case bounded so we never breach the hard timeout.
MAX_RETRIES=3
RETRY_BACKOFF_BASE_SECONDS=1.0

# =============================================================================
# Conversation Memory (Day 3)
# =============================================================================
# Maximum number of recent conversation turns to load into context.
# 10 turns balances clinical accuracy (preserving symptom context) with
# the <4s latency NFR and the 512-token response budget.
MEMORY_MESSAGE_LIMIT=10

# Token budget for conversation history (~60% of 512 max_tokens).
# Leaves ~205 tokens for the current response generation.
MEMORY_MAX_TOKENS=307

# Enable tiktoken for accurate token counting. Set to false on Windows
# if tiktoken installation fails (Rust/C extension compilation error).
TIKTOKEN_ENABLED=false

# =============================================================================
# Intent Classification (Day 4)
# =============================================================================
# Model for intent classification: llama-3.1-8b-instant is chosen because
# it's ~10x cheaper and ~3x faster than the 70B model, and 5-way
# classification is a simple task that 8B handles well.
INTENT_MODEL=llama-3.1-8b-instant

# Hard timeout for intent classification (500ms).
# If this is breached, we fall back to GENERAL and proceed with the
# main LLM call rather than failing the entire request.
INTENT_CLASSIFICATION_TIMEOUT=0.5

# Confidence threshold for accepting intent classification.
# Below this, we fall back to GENERAL for safety.
# 0.7 provides good precision while allowing reasonable recall.
INTENT_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# Embeddings (stubbed for RAG pipeline - Day 5+)
# =============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
DEBUG=True